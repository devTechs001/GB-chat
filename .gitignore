# Root .gitignore for GBChat repository

# Environment files (NEVER commit)
.env
.env.*
!.env.example
!.env.netlify
!.env.render

# Node modules
node_modules/

# Build outputs
dist/
build/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS files
.DS_Store
Thumbs.db

# IDE files
.vscode/
.idea/
*.swp
*.swo

# Temporary files
*.tmp
*.temp
.cache/
