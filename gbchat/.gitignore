# ============================================
# ENVIRONMENT VARIABLES & SECRETS
# ============================================
# NEVER commit files containing secrets, keys, or passwords

# Root environment files
.env
.env.local
.env.development
.env.development.local
.env.test
.env.test.local
.env.production
.env.production.local
.env.staging
.env.staging.local

# Deployment environment files (keep templates, ignore filled versions)
.env.netlify
.env.render
!.env.netlify.example
!.env.render.example

# Server environment files
server/.env
server/.env.local
server/.env.*.local

# Client environment files
client/.env
client/.env.local
client/.env.*.local

# Backup environment files
*.env.bak
*.env.backup
*.env.old

# ============================================
# CREDENTIALS & KEYS
# ============================================
# API Keys, Tokens, and Secrets

# Private keys
*.pem
*.key
*.p12
*.pfx
id_rsa
id_rsa.*
*.ppk

# Certificates
*.crt
*.cer
*.der

# Credentials
credentials
credentials.json
service-account*.json
firebase-*.json
google-credentials.json

# Database files
*.sqlite
*.sqlite3
*.db
data.db

# ============================================
# UPLOADS & USER GENERATED CONTENT
# ============================================
server/uploads/
server/public/uploads/
uploads/
public/uploads/
media/
avatars/
temp/
tmp/

